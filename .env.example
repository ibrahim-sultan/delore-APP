# MongoDB Connection String (Required)
# Get this from MongoDB Atlas or your MongoDB provider
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/deloredb?retryWrites=true&w=majority

# JWT Secret for authentication (Required)
# Generate a secure random string: run `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_SECRET=your-super-secret-jwt-key-change-this

# Email Configuration (Optional - for sending emails)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Node Environment
NODE_ENV=production
